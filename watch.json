{
  "install": {
    "include": ["^package\\.json$", "^pnpm-lock\\.yaml$", "^pnpm-workspace\\.yaml$", "^packages/", "^glitch-start\\.js$", "^watch\\.json$"]
  },
  "restart": {
    "exclude": ["^node_modules/", "^\\.data/", "^packages/backend/dist/"],
    "include": ["^packages/backend/src/", "^packages/shared/src/", "^glitch-start\\.js$"]
  },
  "build": "npm install -g pnpm@9 && pnpm install && pnpm --filter shared build && pnpm --filter backend build",
  "start": "node glitch-start.js"
}
